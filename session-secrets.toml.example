[defaults]
import_backend = "auto"
prompt_import_mode = "allow_and_scrub"
default_dotenv_path = ".env"
keychain_service = "session-secrets-guard"

[aliases.github_token]
env_name = "GITHUB_TOKEN"
source = "env"
name = "GITHUB_TOKEN"

[aliases.openai_api_key]
env_name = "OPENAI_API_KEY"
source = "dotenv"
path = ".env"
key = "OPENAI_API_KEY"

[aliases.npm_token]
env_name = "NPM_TOKEN"
source = "keychain"
service = "session-secrets-guard"
account = "npm-token"

[aliases.linear_api_key]
env_name = "LINEAR_API_KEY"
source = "op"
secret_ref = "op://Private/Linear/api_key"

[aliases.demo_vault_token]
env_name = "DEMO_TOKEN"
source = "vault"
mount = "secret"
path = "app/demo"
field = "token"

[aliases.custom_secret]
env_name = "CUSTOM_SECRET"
source = "command"
command = ["bash", "-lc", "pass show my/custom/secret | head -n 1"]
