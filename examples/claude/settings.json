{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/ruby ./scripts/user_prompt_submit_guard.rb --runtime claude",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/ruby ./scripts/pre_tool_use_guard.rb --runtime claude",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/ruby ./scripts/post_tool_use_guard.rb --runtime claude",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
